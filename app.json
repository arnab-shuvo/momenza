{
  "expo": {
    "name": "TaskManager",
    "slug": "taskmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#5B5FED"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.momenza.taskmanager",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B5FED"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "newArchEnabled": false,
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "10926bf9-126c-4f2e-b2d1-fca6bdfc65c5"
      }
    }
  }
}
